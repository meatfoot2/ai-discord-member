# Copy this file to .env and fill in real values. NEVER commit .env.

# Required: token from https://discord.com/developers/applications -> your bot -> Bot -> Reset Token
DISCORD_BOT_TOKEN=

# Required: API key from https://console.groq.com/keys (free, no credit card required)
GROQ_API_KEY=

# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile
BOT_PERSONA_NAME=alex
# Comma-separated list of channel IDs the bot is allowed to talk in.
# Leave blank to allow every text channel it can see.
ALLOWED_CHANNEL_IDS=
# Probability (0-1) that the bot chimes in on a message where it wasn't mentioned.
UNPROMPTED_REPLY_CHANCE=0.75
# Minimum seconds between the bot's own messages in a single channel (rate limit).
PER_CHANNEL_COOLDOWN_SECONDS=6
# How many recent messages per channel to keep as conversation memory.
CONTEXT_WINDOW_MESSAGES=25
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Directory to write the chat log (one JSON line per message/reply, rotates daily).
CHAT_LOG_DIR=logs
# Chat log filename (rotated files get a .YYYY-MM-DD suffix).
CHAT_LOG_FILENAME=chat.log
# How many days of rotated chat logs to keep.
CHAT_LOG_BACKUP_DAYS=30
# Name of a text channel in each guild to mirror every message + reply into
# (in real time). Create the channel manually in Discord; if it doesn't exist,
# mirroring is silently skipped. Set to blank to disable.
LOG_CHANNEL_NAME=bot-logs
# SQLite file that stores persistent chat history + per-user facts the bot
# has learned. Survives restarts. Path is relative to the working directory.
MEMORY_DB_PATH=data/memory.db
# Max number of long-term facts to keep per user (oldest trimmed first).
MAX_FACTS_PER_USER=40
